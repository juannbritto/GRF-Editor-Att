<Styles:TkWindow x:Class="GRFEditor.WPF.SafeSaveReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        Background="{DynamicResource TabItemBackground}" Foreground="{DynamicResource TextForeground}"
        Width="680" Height="430" MinWidth="520" MinHeight="320">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="_summary" FontWeight="Bold" Margin="0 0 0 8" />
        <Grid Grid.Row="1">
            <TextBox x:Name="_reportText" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
            <ListBox x:Name="_temporaries" Visibility="Collapsed" />
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 8 0 0">
            <Button x:Name="_inspect" Content="Inspect location" Width="120" Margin="3" Visibility="Collapsed" Click="_inspect_Click" />
            <Button x:Name="_remove" Content="Remove selected temporary" Width="185" Margin="3" Visibility="Collapsed" Click="_remove_Click" />
            <Button Content="Close" Width="90" Margin="3" IsCancel="True" />
        </StackPanel>
    </Grid>
</Styles:TkWindow>

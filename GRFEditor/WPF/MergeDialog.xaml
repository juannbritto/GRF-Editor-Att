<Styles:TkWindow x:Class="GRFEditor.WPF.MergeDialogCustom"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
		xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
		Background="{StaticResource GrfCanvasBrush}" Foreground="{StaticResource GrfTextBrush}" UseLayoutRounding="True" SnapsToDevicePixels="True" MinWidth="520">
	<StackPanel>
        <TextBlock Margin="3" Text="Merging cannot be undone." TextWrapping="Wrap" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Label Content="Base GRF" VerticalAlignment="Center" />
            <Label Content="Added GRF" VerticalAlignment="Center" Grid.Row="1" />
            <Styles:PathBrowser BrowseMode="File"  Name="_pathBrowserOldGrf" Filter="Container Files|*.grf;*.gpf;*.thor" TextChanged="_pathBrowserOldGrf_TextChanged" Grid.Column="1" UseSavePath="True" SavePathUniqueName="GRFEditor - Merge old - " MaxWidth="350" MinWidth="350" />
            <Styles:PathBrowser BrowseMode="File" Name="_pathBrowserNewGrf" Filter="Container Files|*.grf;*.gpf;*.thor" TextChanged="_pathBrowserNewGrf_TextChanged" Grid.Row="1" Grid.Column="1" UseSavePath="True" SavePathUniqueName="GRFEditor - Merge new - " MaxWidth="350" MinWidth="350" />
            <Styles:TkProgressBar x:Name="_progressBarComponent" Grid.Row="3" Grid.Column="1" Margin="3" />
        </Grid>
        <Border TokeiLibrary:WpfProperties.IsDraggable="True" Style="{StaticResource GrfDialogFooter}">
            <Grid Margin="0 0 3 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="2">
                    <Button Name="_buttonOK" Content="Merge" Style="{StaticResource GrfDangerButton}" MinWidth="100" Margin="0,0,8,0" Click="_buttonOK_Click" />
                    <Button HorizontalAlignment="Right" Name="_buttonCancel" Content="Close" Style="{StaticResource GrfSecondaryButton}" MinWidth="100" Click="_buttonCancel_Click" />
                </DockPanel>
            </Grid>
        </Border>
    </StackPanel>
</Styles:TkWindow>

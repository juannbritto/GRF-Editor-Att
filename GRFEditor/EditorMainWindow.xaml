<Window x:Class="GRFEditor.EditorMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
        xmlns:WPF="clr-namespace:TokeiLibrary.WPF;assembly=TokeiLibrary"
        xmlns:ListView="clr-namespace:TokeiLibrary.WPF.Styles.ListView;assembly=TokeiLibrary"
        xmlns:WpfBugFix="clr-namespace:TokeiLibrary.WpfBugFix;assembly=TokeiLibrary"
		Title="GRF Editor Safe" Height="680" Width="1040" Icon="Resources\internalapp.png" MinWidth="820" MinHeight="520" SnapsToDevicePixels="True" UseLayoutRounding="True"
        Background="{StaticResource GrfCanvasBrush}" Foreground="{StaticResource GrfTextBrush}">
    <Window.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Window.Resources>
    <Grid DragEnter="_menu_DragEnter" Drop="_menu_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="42" />
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Height="30" AllowDrop="True" Background="{StaticResource GrfSurfaceBrush}">
            <MenuItem Margin="0 0 0 0">
                <MenuItem.Header>
                    <Label Content="File" Name="_miFile" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-5 0 -5 0" />
                </MenuItem.Header>
				<MenuItem TokeiLibrary:WpfProperties.ImagePath="add.png">
                    <MenuItem.Header>
                        <TextBlock Text="New" Margin="3 0 0 0" VerticalAlignment="Center" />
                    </MenuItem.Header>
                    <MenuItem Name="_menuItemNewGrf" TokeiLibrary:WpfProperties.ImagePath="grf-16.png" Header="Grf" InputGestureText="Ctrl-N" Click="_menuItemNewGrf_Click" />
                    <MenuItem TokeiLibrary:WpfProperties.ImagePath="gpf-16.png" Header="Gpf" Click="_menuItemNewGpf_Click" />
                    <MenuItem Name="_menuItemNewRgz" TokeiLibrary:WpfProperties.ImagePath="rgz-16.png" Header="Rgz" Click="_menuItemNewRgz_Click" />
                    <MenuItem Name="_menuItemNewThor" TokeiLibrary:WpfProperties.ImagePath="thor-16.png" Header="Thor" Click="_menuItemNewThor_Click" />
                </MenuItem>
                <MenuItem Name="_menuItemOpenFrom" TokeiLibrary:WpfProperties.ImagePath="newFile.png" Header="Open..." InputGestureText="Ctrl-O" Click="_menuItemOpenFrom_Click" />
                <MenuItem Name="_menuItemRecentFiles" TokeiLibrary:WpfProperties.ImagePath="empty.png" Header="Open recent" />
                <Separator />
                <MenuItem Name="_menuItemCloseGrf" TokeiLibrary:WpfProperties.ImagePath="empty.png" Header="Close Grf" Click="_menuItemCloseGrf_Click" />
                <Separator />
				<MenuItem Name="_menuItemSave" TokeiLibrary:WpfProperties.ImagePath="save.png" Header="Save safely" InputGestureText="Ctrl-S" Click="_menuItemSave_Click" />
				<MenuItem Name="_menuItemSaveAs" TokeiLibrary:WpfProperties.ImagePath="empty.png" Header="Save as..." Click="_menuItemSaveAs_Click" />
				<MenuItem Name="_menuItemRestoreBackup" TokeiLibrary:WpfProperties.ImagePath="refresh.png" Header="Restore validated .bak" Click="_menuItemRestoreBackup_Click" />
				<MenuItem Name="_menuItemLastSafeSaveReport" TokeiLibrary:WpfProperties.ImagePath="warning16.png" Header="Last safe-save report" IsEnabled="False" Click="_menuItemLastSafeSaveReport_Click" />
                <MenuItem Header="Save advanced" TokeiLibrary:WpfProperties.ImagePath="empty.png">
                    <MenuItem Name="_menuItemDefragment" TokeiLibrary:WpfProperties.ImagePath="defrag.png" Header="Defragment (quick)" Click="_menuItemDefragment_Click" InputGestureText="Ctrl-Shift-S" />
                    <MenuItem Name="_menuItemCompact" TokeiLibrary:WpfProperties.ImagePath="redirect.png" Header="Compact (redirect indexes)" Click="_menuItemCompact_Click" InputGestureText="Ctrl-Alt-S" />
                    <MenuItem Name="_menuItemRepack" TokeiLibrary:WpfProperties.ImagePath="pack.png" Header="Repack (recompress)" Click="_menuItemRepack_Click" />
                    <MenuItem Name="_menuItemEncryptTable" TokeiLibrary:WpfProperties.ImagePath="lock.png" Header="Encrypt File Table" Click="_menuItemTableEncrypt_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Name="_menuItemAbout" TokeiLibrary:WpfProperties.ImagePath="help.png" Header="About..." Click="_menuItemAbout_Click" />
                <MenuItem Name="_menuItemQuit" TokeiLibrary:WpfProperties.ImagePath="empty.png" Header="Quit" Click="_menuItemQuit_Click" />
            </MenuItem>
            <MenuItem VerticalAlignment="Center" Visibility="Visible">
                <MenuItem.Header>
                    <Label Content="Edit" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-5 0 -5 0" />
                </MenuItem.Header>
                <MenuItem Name="_buttonUndo" TokeiLibrary:WpfProperties.ImagePath="undo.png" IsEnabled="false" Header="Undo" InputGestureText="Ctrl-Z" Click="_buttonUndo_Click" />
                <MenuItem Name="_buttonRedo" TokeiLibrary:WpfProperties.ImagePath="redo.png" IsEnabled="false" Header="Redo" InputGestureText="Ctrl-Y" Click="_buttonRedo_Click" />
                <MenuItem Name="_buttonPositionUndo" IsEnabled="false" Header="Navigate backward" InputGestureText="Alt-Z" Click="_buttonPositionUndo_Click">
                    <MenuItem.Icon>
                        <Image Source="Resources\forward.png" Width="16" Height="16" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform ScaleX="-1"/>
                            </Image.RenderTransform>
                        </Image>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="_buttonPositionRedo" TokeiLibrary:WpfProperties.ImagePath="forward.png" IsEnabled="false" Header="Navigate forward" InputGestureText="Alt-Y" Click="_buttonPositionRedo_Click" />
                <MenuItem Name="_menuItemMerge" TokeiLibrary:WpfProperties.ImagePath="addgrf.png" Header="Merge" InputGestureText="Ctrl-M" Click="_menuItemMerge_Click" />
                <MenuItem Name="_menuItemSoustract" TokeiLibrary:WpfProperties.ImagePath="subgrf.png" Header="Subtract" Click="_menuItemSoustract_Click" />
                <Separator />
                <MenuItem Name="_menuItemExtractRgz" TokeiLibrary:WpfProperties.ImagePath="archive.png" Header="Extract Rgz" IsEnabled="False" Click="_menuItemExtractRgz_Click" />
                <Separator />
                <MenuItem Name="_menuItemEditContainerSettings" TokeiLibrary:WpfProperties.ImagePath="properties.png" Header="Edit Grf/Thor settings" Click="_menuItemEditContainerSettings_Click" />
            </MenuItem>
            <MenuItem VerticalAlignment="Center" Visibility="Visible">
                <MenuItem.Header>
                    <Label Content="Tools" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-5 0 -5 0" />
                </MenuItem.Header>
                <MenuItem Name="_menuItemValidateGrf" TokeiLibrary:WpfProperties.ImagePath="validity.png" Header="Grf validation" Click="_menuItemValidateGrf_Click" />
                <MenuItem Name="_menuItemOpenProgramData" TokeiLibrary:WpfProperties.ImagePath="newFolder.png" Click="_menuItemOpenProgramData_Click" Header="Open roaming data" />
                <Separator />
                <MenuItem Name="_menuItemImportSprite" TokeiLibrary:WpfProperties.ImagePath="convert.png" Header="Import sprite..." Click="_menuItemImportSprite_Click" />
                <Separator />
                <MenuItem Name="_menuItemSpriteConverter" TokeiLibrary:WpfProperties.ImagePath="spritemaker.png" Header="Sprite editor" Click="_menuItemSpriteConverter_Click" />
                <MenuItem Name="_menuItemFlatMapsMaker" TokeiLibrary:WpfProperties.ImagePath="mapEditor.png" Header="Flat maps maker" Click="_menuItemFlatMapsMaker_Click" />
                <MenuItem Name="_menuItemPatchMaker" TokeiLibrary:WpfProperties.ImagePath="diff.png" Header="Patch maker" Click="_menuItemPatchMaker_Click" />
                <MenuItem Name="_menuItemHash" TokeiLibrary:WpfProperties.ImagePath="hash.png" Header="Hash viewer" Click="_menuItemHash_Click" />
                <MenuItem Name="_menuItemEncoding" TokeiLibrary:WpfProperties.ImagePath="refresh.png" Header="Text encoding" Click="_menuItemEncoding_Click" />
                <MenuItem Name="_menuItemSearch" TokeiLibrary:WpfProperties.ImagePath="search.png" Header="Advanced search" Click="_menuItemSearch_Click" />
                <MenuItem Name="_menuItemImageConverter" TokeiLibrary:WpfProperties.ImagePath="imconvert.png" Header="Image converter" Click="_menuItemImageConverter_Click" />
                <MenuItem Name="_menuItemGrfCL" TokeiLibrary:WpfProperties.ImagePath="dos.png" Header="GRF Command Line" Click="_menuItemGrfCL_Click" />
                <MenuItem Name="_menuItemOpenGL" TokeiLibrary:WpfProperties.ImagePath="warning16.png" Header="OpenGL Logger" Click="_menuItemOpenGL_Click" />
                <!--<MenuItem Name="_menuItemImageRecon" ListView:WpfUtils.ImagePath="imconvert.png" Header="Image finder" Click="_menuItemImageRecon_Click" />-->
                <MenuItem Name="_menuItemEncryptor" TokeiLibrary:WpfProperties.ImagePath="lock.png" IsEnabled="True" Header="GRF Encryption" Click="_menuItemEncryptor_Click" />
                <!--<MenuItem Name="_menuItemPatcher" IsEnabled="True" Header="Grf patcher" Click="_menuItemPatcher_Click">
                    <MenuItem.Icon>
                        <Image Source="Resources\lock.png" Height="16"  />
                    </MenuItem.Icon>
                </MenuItem>-->
                <Separator />
                <MenuItem Name="_menuItemSettings" Header="Settings" Click="_menuItemSettings_OnClick">
                    <MenuItem.Icon>
                        <Image Source="Resources\settings.png" Width="16" Height="16"  />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>
        <Border Grid.Row="1" Background="{StaticResource GrfSurfaceBrush}" BorderBrush="{StaticResource GrfBorderBrush}" BorderThickness="0,1,0,1" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="230" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="_buttonOpenToolbar" Content="Open" Style="{StaticResource GrfSecondaryButton}" MinWidth="74" Margin="0,0,6,0" Click="_menuItemOpenFrom_Click" ToolTip="Open a GRF or supported container (Ctrl+O)" />
                    <Button x:Name="_buttonSaveToolbar" Content="Save safely" Style="{StaticResource GrfPrimaryButton}" MinWidth="104" Click="_menuItemSave_Click" ToolTip="Validate a copy before replacing the current GRF (Ctrl+S)" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <WpfBugFix:ToggleMemoryButton x:Name="_tmbUndo" IsEnabled="false" PrimaryButtonImagePath="undo.png" DisplayFormat="Undo {0} action" />
                    <WpfBugFix:ToggleMemoryButton x:Name="_tmbRedo" IsEnabled="false" PrimaryButtonImagePath="redo.png" DisplayFormat="Redo {0} action" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0">
                    <Styles:FancyButton x:Name="_buttonFancyBackward" Height="28" Width="28" TokeiLibrary:WpfProperties.ImagePath="backward.png" Click="_buttonPositionUndo_Click" IsButtonEnabled="False" ToolTip="Navigate backward (Alt+Z)" />
                    <Styles:FancyButton x:Name="_buttonFancyForward" Height="28" Width="28" TokeiLibrary:WpfProperties.ImagePath="forward.png" Click="_buttonPositionRedo_Click" IsButtonEnabled="False" ToolTip="Navigate forward (Alt+Y)" />
                </StackPanel>
                <Grid Grid.Column="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Image Source="Resources\find.png" Height="16" Width="16" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Name="_textBoxMainSearch" Height="28" TextChanged="_textBox_TextChanged" VerticalContentAlignment="Center" ToolTip="Search in the complete archive" />
                </Grid>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="{StaticResource GrfSurfaceAltBrush}" BorderBrush="{StaticResource GrfBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Archive" FontWeight="SemiBold" Foreground="{StaticResource GrfMutedTextBrush}" Margin="0,0,8,0" />
                    <TextBlock x:Name="_archivePathText" Text="No container open" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                </StackPanel>
                <Styles:TkProgressBar Grid.Column="1" x:Name="_progressBarComponent" Margin="10,0" />
                <Border Grid.Column="2" x:Name="_safeSaveStateBorder" Style="{StaticResource GrfSafeStatusBorder}" MinWidth="210">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="_safeSaveStateIcon" Text="•" FontWeight="Bold" Margin="0,0,6,0" />
                        <TextBlock x:Name="_safeSaveStateText" Text="Safe save: waiting for a container" TextTrimming="CharacterEllipsis" ToolTipService.ShowDuration="30000" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Row="3" Name="_primaryGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="468" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- Left Panel -->
            <Grid x:Name="_gridGrfContent" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Name="_rDefSearch" Height="auto" />
                    <RowDefinition Name="_rDefSearchSplitter" Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                
                <!-- Set to hidden to force render the size on loading -->
                <ListView
                    Visibility="Hidden"
                    TextSearch.TextPath="DisplayRelativePath"
                    Grid.Row="2"
                    Name="_listBoxResults"
                    SelectionChanged="_listBoxResults_SelectionChanged"
                    SelectionMode="Extended"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}"
                    ListView:ListViewExtensions.IsGridSortable="True"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    KeyDown="_listBoxResults_KeyDown" PreviewMouseRightButtonUp="_listBoxResults_PreviewMouseRightButtonUp">
                </ListView>

                <GridSplitter Name="_gridSplitterSearch" Visibility="Collapsed" MinHeight="0" Height="2" HorizontalAlignment="Stretch" Grid.Row="1" VerticalAlignment="Stretch" Background="{x:Static TokeiLibrary:Configuration.UIGridBackground}" />

                <Grid x:Name="_gridTreeView" Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="198" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource GrfSurfaceAltBrush}" BorderBrush="{StaticResource GrfBorderBrush}" BorderThickness="0,0,0,1" Padding="8,0">
                        <TextBlock Text="Folders" Style="{StaticResource GrfPaneHeader}" />
                    </Border>
                    <!-- TreeView and ListView -->
                    <WPF:TkView Grid.Row="1" Grid.Column="0" BorderThickness="0" Margin="0" Name="_treeView" Drop="_treeView_Drop" SelectedItemChanged="_treeView_SelectedItemChanged" KeyDown="_treeView_KeyDown" PreviewMouseRightButtonUp="_treeView_PreviewMouseRightButtonUp" PreviewMouseRightButtonDown="_treeView_PreviewMouseRightButtonDown" />
                    <GridSplitter Grid.RowSpan="2" Width="2" Grid.Column="1" HorizontalAlignment="Left" Background="{StaticResource GrfBorderBrush}" />
                    <Grid Grid.RowSpan="2" Grid.Column="2" Background="{DynamicResource ListItemSearchBackground}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource GrfSurfaceAltBrush}" BorderBrush="{StaticResource GrfBorderBrush}" BorderThickness="0,0,0,1" Padding="8,0">
                            <TextBlock Text="Files" Style="{StaticResource GrfPaneHeader}" />
                        </Border>
                        <DockPanel Grid.Row="1">
                            <Image Margin="5,0,0,0" Source="Resources\filter.png" Height="16" Width="16" VerticalAlignment="Center" />
                            <TextBox Name="_textBoxSearch" Height="28" Margin="3" TextChanged="_textBoxSearch_TextChanged" VerticalAlignment="Center" VerticalContentAlignment="Center" ToolTip="Filter the current folder" />
                        </DockPanel>
                        <ListView TextSearch.TextPath="DisplayRelativePath" AllowDrop="True" Grid.Row="2" Name="_items" SelectionChanged="_items_SelectionChanged"  SelectionMode="Extended" DragEnter="_items_DragEnter" DragLeave="_items_DragLeave" Drop="_items_Drop"
		                    PreviewMouseLeftButtonDown="_items_PreviewMouseLeftButtonDown" BorderThickness="0" PreviewMouseRightButtonUp="_items_PreviewMouseRightButtonUp" KeyDown="_items_KeyDown" FocusVisualStyle="{x:Null}"
		                    ListView:ListViewExtensions.IsGridSortable="True" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        </ListView>
                    </Grid>
                </Grid>
            </Grid>
            <GridSplitter Name="_gridSplitterPanels" Width="2" Grid.Column="1" HorizontalAlignment="Left" Background="{x:Static TokeiLibrary:Configuration.UIGridBackground}" />
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource GrfSurfaceAltBrush}" BorderBrush="{StaticResource GrfBorderBrush}" BorderThickness="0,0,0,1" Padding="8,0">
                    <TextBlock Text="Preview" Style="{StaticResource GrfPaneHeader}" />
                </Border>
                <Border Grid.Row="1" Background="{DynamicResource TabControlBackground}">
                    <Grid>
                        <TabControl Name="_tabControlPreview" Style="{DynamicResource TabControlStyled}" SnapsToDevicePixels="True">
                        </TabControl>
                        <Styles:FancyButton x:Name="_buttonExpand" Click="_buttonExpand_Click" TextHeader="Hide" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="35" Width="70" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Border Grid.Row="4" Background="{StaticResource GrfSurfaceAltBrush}" BorderBrush="{StaticResource GrfBorderBrush}" BorderThickness="0,1,0,0" Padding="8,4">
            <DockPanel>
                <TextBlock x:Name="_fileCountText" Text="0 files" Foreground="{StaticResource GrfMutedTextBrush}" DockPanel.Dock="Right" />
                <TextBlock Text="Ready" Foreground="{StaticResource GrfMutedTextBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
